---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Cas-Per affianca le imprese funebri nella digitalizzazione del cordoglio con AnnunciFunebri.it e soluzioni su misura.",
} = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/webp" href="/assets/iconacasper-small.webp" />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <aside class="side-nav" aria-label="Navigazione principale">
        <a class="side-brand" href="/" aria-label="Cas-Per home">
          <img src="/assets/Risorsa-1cp.png" alt="Cas-Per" />
        </a>
        <nav>
          <a href="/">Home</a>
          <a href="/#chi-siamo">Chi siamo</a>
          <a href="/#servizi">Servizi</a>
          <a href="/#testimonianze">Dicono di noi</a>
          <a href="/#contatti">Contatti</a>
        </nav>
        <a class="side-cta" href="/diventa-impresa-affiliata/">AF</a>
      </aside>

      <header class="mobile-header">
        <a class="brand" href="/" aria-label="Cas-Per home">
          <img src="/assets/casper-orizzontale.webp" alt="Cas-Per" />
        </a>
        <nav aria-label="Navigazione mobile">
          <a href="/#servizi">Servizi</a>
          <a href="/diventa-impresa-affiliata/">Affiliazione</a>
          <a href="/#contatti">Contatti</a>
        </nav>
      </header>

      <div class="page-frame">
        <main>
          <slot />
        </main>
        <footer class="site-footer">
          <div>
            <img src="/assets/casper-orizzontale.webp" alt="Cas-Per" />
            <p>Tecnologia a servizio del settore funebre.</p>
          </div>
          <p>Cas-Per Srl - Tarcento</p>
        </footer>
      </div>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f8f8f6;
    --paper: #ffffff;
    --ink: #243134;
    --muted: #6f7c80;
    --line: #e3e6e4;
    --brand: #1396a7;
    --brand-dark: #0d6170;
    --accent: #c39a76;
    --rose: #d99b9b;
    --soft: #edf5f3;
    --sidebar: #f3f4f1;
    --shadow: 0 20px 60px rgba(32, 49, 53, 0.1);
    font-family: "Segoe UI", Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: var(--ink);
    background: var(--bg);
    line-height: 1.6;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .site-shell {
    min-height: 100vh;
  }

  .side-nav {
    position: fixed;
    inset: 0 auto 0 0;
    z-index: 20;
    display: flex;
    width: 128px;
    align-items: center;
    flex-direction: column;
    justify-content: space-between;
    gap: 28px;
    padding: 28px 18px;
    border-right: 1px solid rgba(227, 230, 228, 0.92);
    background: rgba(243, 244, 241, 0.96);
    backdrop-filter: blur(14px);
  }

  .side-brand img {
    width: 86px;
    height: auto;
  }

  .side-nav nav {
    display: flex;
    align-items: center;
    flex-direction: column;
    gap: 18px;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
    text-align: center;
    text-transform: lowercase;
  }

  .side-nav nav a {
    text-decoration: none;
  }

  .side-nav nav a:hover {
    color: var(--brand-dark);
  }

  .side-cta {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border: 1px solid var(--line);
    border-radius: 50%;
    background: var(--paper);
    color: var(--brand-dark);
    font-size: 0.78rem;
    font-weight: 800;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(32, 49, 53, 0.07);
  }

  .mobile-header {
    display: none;
  }

  .brand img {
    width: 148px;
    height: auto;
  }

  .mobile-header nav {
    display: flex;
    gap: 16px;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .mobile-header nav a {
    text-decoration: none;
  }

  .page-frame {
    margin-left: 128px;
  }

  .nav-cta,
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 20px;
    border-radius: 6px;
    background: var(--brand);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
  }

  .button.secondary {
    border: 1px solid var(--line);
    background: var(--paper);
    color: var(--brand-dark);
  }

  .section {
    padding: clamp(64px, 8vw, 112px) clamp(24px, 5vw, 76px);
  }

  .container {
    width: min(1160px, 100%);
    margin: 0 auto;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--brand-dark);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 760px;
    font-size: clamp(2.8rem, 6.8vw, 6.2rem);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: 0;
  }

  h1 strong {
    color: var(--brand-dark);
    font-weight: 750;
  }

  h2 {
    max-width: 760px;
    font-size: clamp(2rem, 4vw, 3.6rem);
    font-weight: 320;
    line-height: 1.04;
    letter-spacing: 0;
  }

  h3 {
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .lead {
    max-width: 760px;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.32rem);
  }

  .hero {
    position: relative;
    min-height: 100vh;
    display: grid;
    align-items: center;
    overflow: hidden;
    padding: clamp(58px, 7vw, 92px) clamp(24px, 5vw, 76px) clamp(34px, 5vw, 64px);
    background:
      url("/assets/art-top00.png") right top / min(66vw, 980px) auto no-repeat,
      linear-gradient(90deg, rgba(248, 248, 246, 1), rgba(248, 248, 246, 0.96));
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(340px, 0.9fr);
    gap: clamp(24px, 4vw, 58px);
    align-items: center;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    color: var(--brand);
    font-size: clamp(1.6rem, 4vw, 3.2rem);
    font-weight: 300;
    line-height: 1;
  }

  .hero-kicker strong {
    color: var(--brand-dark);
    font-weight: 750;
  }

  .hero-note {
    align-self: start;
    justify-self: end;
    max-width: 300px;
    margin-top: 10px;
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.7;
    text-transform: uppercase;
  }

  .hero-visual {
    position: relative;
    align-self: end;
    min-height: 520px;
  }

  .hero-visual img {
    position: absolute;
    right: min(2vw, 24px);
    bottom: 0;
    width: min(48vw, 620px);
    max-width: none;
  }

  .hero-card {
    position: absolute;
    right: 0;
    bottom: clamp(34px, 6vw, 86px);
    width: min(280px, 70%);
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: var(--shadow);
  }

  .hero-card span {
    display: block;
    margin-bottom: 8px;
    color: var(--brand-dark);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .hero-card p {
    margin-bottom: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    overflow: hidden;
    border: 1px solid rgba(227, 230, 228, 0.86);
    border-radius: 8px;
    background: var(--line);
  }

  .stat {
    min-height: 124px;
    padding: 26px;
    background: var(--paper);
  }

  .stat strong {
    display: block;
    color: var(--brand-dark);
    font-size: clamp(1.7rem, 3vw, 2.7rem);
    line-height: 1;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .card,
  blockquote {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    padding: 28px;
    box-shadow: 0 8px 30px rgba(15, 42, 47, 0.05);
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
  }

  .media-panel {
    overflow: hidden;
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .soft {
    background: var(--soft);
  }

  .dark {
    background: #273639;
    color: #fff;
  }

  .dark .lead,
  .dark p {
    color: rgba(255, 255, 255, 0.78);
  }

  .steps {
    counter-reset: steps;
    display: grid;
    gap: 14px;
    padding: 0;
    list-style: none;
  }

  .steps li {
    counter-increment: steps;
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 16px;
    align-items: start;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
  }

  .steps li::before {
    content: counter(steps);
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--brand);
    color: #fff;
    font-weight: 800;
  }

  blockquote {
    margin: 0;
  }

  blockquote p {
    color: var(--ink);
    font-size: 1.02rem;
  }

  cite {
    color: var(--muted);
    font-style: normal;
    font-size: 0.92rem;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding: 36px clamp(24px, 5vw, 76px);
    border-top: 1px solid var(--line);
    color: var(--muted);
    background: var(--paper);
  }

  .site-footer img {
    width: 132px;
    margin-bottom: 8px;
  }

  @media (max-width: 980px) {
    .side-nav {
      display: none;
    }

    .page-frame {
      margin-left: 0;
    }

    .mobile-header {
      position: sticky;
      top: 0;
      z-index: 20;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding: 16px 20px;
      border-bottom: 1px solid rgba(227, 230, 228, 0.92);
      background: rgba(248, 248, 246, 0.96);
      backdrop-filter: blur(14px);
    }

    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .mobile-header nav {
      width: 100%;
      overflow-x: auto;
      padding-bottom: 4px;
    }

    .hero {
      min-height: auto;
      background:
        url("/assets/art-top00.png") right top / 140vw auto no-repeat,
        linear-gradient(180deg, rgba(248, 248, 246, 1), rgba(248, 248, 246, 0.96));
    }

    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-note {
      justify-self: start;
      margin-top: 0;
    }

    .hero-visual {
      min-height: 420px;
    }

    .hero-visual img {
      right: 50%;
      width: min(680px, 112vw);
      transform: translateX(50%);
    }

    .hero-card {
      right: 50%;
      width: min(320px, 86vw);
      transform: translateX(50%);
    }

    .stats,
    .grid,
    .split {
      grid-template-columns: 1fr;
    }
  }
</style>
