---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Cas-Per affianca le imprese funebri nella digitalizzazione del cordoglio con AnnunciFunebri.it e soluzioni su misura.",
} = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/webp" href="/assets/iconacasper-small.webp" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Cas-Per home">
        <img src="/assets/casper-orizzontale.webp" alt="Cas-Per" />
      </a>
      <nav aria-label="Navigazione principale">
        <a href="/#servizi">Servizi</a>
        <a href="/#testimonianze">Dicono di noi</a>
        <a href="/diventa-impresa-affiliata/">Affiliazione</a>
        <a class="nav-cta" href="/#contatti">Contatti</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <img src="/assets/casper-orizzontale.webp" alt="Cas-Per" />
        <p>Tecnologia a servizio del settore funebre.</p>
      </div>
      <p>Cas-Per Srl - Tarcento</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f6f8f7;
    --paper: #ffffff;
    --ink: #1f2b2d;
    --muted: #647174;
    --line: #dfe7e5;
    --brand: #118a9c;
    --brand-dark: #0b5e6d;
    --accent: #b69b62;
    --soft: #e8f3f2;
    --shadow: 0 22px 80px rgba(15, 42, 47, 0.12);
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: var(--ink);
    background: var(--bg);
    line-height: 1.6;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 18px clamp(18px, 4vw, 56px);
    border-bottom: 1px solid rgba(223, 231, 229, 0.82);
    background: rgba(246, 248, 247, 0.94);
    backdrop-filter: blur(16px);
  }

  .brand img {
    width: 160px;
    height: auto;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 22px;
    color: var(--muted);
    font-size: 0.95rem;
  }

  nav a {
    text-decoration: none;
  }

  .nav-cta,
  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 20px;
    border-radius: 6px;
    background: var(--brand);
    color: #fff;
    text-decoration: none;
    font-weight: 700;
  }

  .button.secondary {
    border: 1px solid var(--line);
    background: var(--paper);
    color: var(--brand-dark);
  }

  .section {
    padding: clamp(64px, 8vw, 112px) clamp(18px, 4vw, 56px);
  }

  .container {
    width: min(1160px, 100%);
    margin: 0 auto;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--brand-dark);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 820px;
    font-size: clamp(2.4rem, 6vw, 5.6rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  h2 {
    max-width: 760px;
    font-size: clamp(2rem, 4vw, 3.6rem);
    line-height: 1.04;
    letter-spacing: 0;
  }

  h3 {
    font-size: 1.15rem;
    line-height: 1.2;
  }

  .lead {
    max-width: 760px;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.32rem);
  }

  .hero {
    min-height: calc(100vh - 82px);
    display: grid;
    align-items: center;
    padding: clamp(48px, 7vw, 96px) clamp(18px, 4vw, 56px);
    background:
      linear-gradient(90deg, rgba(246, 248, 247, 0.98) 0%, rgba(246, 248, 247, 0.86) 52%, rgba(246, 248, 247, 0.2) 100%),
      url("/assets/annuncifunebri_pc-1.jpg") right center / min(48vw, 760px) auto no-repeat;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 30px;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--line);
  }

  .stat {
    min-height: 124px;
    padding: 26px;
    background: var(--paper);
  }

  .stat strong {
    display: block;
    color: var(--brand-dark);
    font-size: clamp(1.7rem, 3vw, 2.7rem);
    line-height: 1;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .card,
  blockquote {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    padding: 28px;
    box-shadow: 0 8px 30px rgba(15, 42, 47, 0.05);
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
  }

  .media-panel {
    overflow: hidden;
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .soft {
    background: var(--soft);
  }

  .dark {
    background: #203235;
    color: #fff;
  }

  .dark .lead,
  .dark p {
    color: rgba(255, 255, 255, 0.78);
  }

  .steps {
    counter-reset: steps;
    display: grid;
    gap: 14px;
    padding: 0;
    list-style: none;
  }

  .steps li {
    counter-increment: steps;
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 16px;
    align-items: start;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
  }

  .steps li::before {
    content: counter(steps);
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--brand);
    color: #fff;
    font-weight: 800;
  }

  blockquote {
    margin: 0;
  }

  blockquote p {
    color: var(--ink);
    font-size: 1.02rem;
  }

  cite {
    color: var(--muted);
    font-style: normal;
    font-size: 0.92rem;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    padding: 36px clamp(18px, 4vw, 56px);
    border-top: 1px solid var(--line);
    color: var(--muted);
    background: var(--paper);
  }

  .site-footer img {
    width: 132px;
    margin-bottom: 8px;
  }

  @media (max-width: 860px) {
    .site-header,
    .site-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    nav {
      width: 100%;
      overflow-x: auto;
      padding-bottom: 4px;
    }

    .hero {
      min-height: auto;
      background:
        linear-gradient(180deg, rgba(246, 248, 247, 0.98), rgba(246, 248, 247, 0.88)),
        url("/assets/annuncifunebri_pc-1.jpg") center bottom / 92vw auto no-repeat;
      padding-bottom: 320px;
    }

    .stats,
    .grid,
    .split {
      grid-template-columns: 1fr;
    }
  }
</style>
